  "keyFeatures": [
    "LDAP corporate authentication with Active Directory",
    "Equipment inspection management with OK/NOK/NA status tracking",
    "SAP integration fields (EQUNR, TPLNR, work center)",
    "IP and hostname-based access control middleware",
    "Weekly inspection assignment scheduling",
    "Django admin panel with Jazzmin UI",
    "MySQL database with Django ORM",
    "CORS support for Next.js frontend integration",
    "Session-based authentication with 1-hour timeout",
    "REST API built with Django REST Framework"
  ],
  "publicApiSurface": [
    "POST /api/login-ldap/",
    "GET /api/logout/",
    "POST /api/guardar/",
    "GET /api/divisiones/",
    "GET /api/areas/",
    "GET /api/zonas/",
    "GET /api/equipos/",
    "GET /api/equipo/<equipo_id>/",
    "GET /api/categorias/",
    "GET /api/preguntas/<categoria_nombre>/",
    "GET /api/dashboard/inspecciones/",
    "GET /api/asignaciones/",
    "POST /api/asignaciones/"
  ]
